<launch>
  <!-- Hector SLAM para odometria via laser -->
  <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
    <param name="map_frame"                             value="hector_map"/>
    <param name="base_frame"                            value="p3dx_tf/base_link"/>
    <param name="odom_frame"                            value="p3dx_tf/odom"/>
    <param name="tf_map_scanmatch_transform_frame_name" value="p3dx_tf/base_link"/>
    <param name="pub_map_odom_transform"                value="false"/>
    <param name="pub_map_scanmatch_transform"           value="true"/>
    <param name="pub_odometry"                          value="true"/>
    <param name="map_resolution"                        value="0.05"/>
    <param name="map_size"                              value="2048"/>
    <param name="map_multi_res_levels"                  value="2"/>
    <param name="map_update_angle_thresh"               value="0.06"/>
    <param name="scan_topic"                            value="/p3dx/laser/scan"/>
  </node>

  <!-- RTAB-Map -->
  <node name="rtabmap" pkg="rtabmap_slam" type="rtabmap" output="screen" args="--delete_db_on_start">
    <param name="subscribe_depth" type="bool"   value="true"/>
    <param name="subscribe_scan"  type="bool"   value="true"/>
    <param name="frame_id"        type="string" value="p3dx_tf/base_link"/>
    <param name="odom_frame_id"   type="string" value="p3dx_tf/odom"/>
    <param name="approx_sync"     type="bool"   value="true"/>
    <param name="use_sim_time"    type="bool"   value="true"/>
    <param name="Reg/Strategy"       type="string" value="2"/>
    <param name="Optimizer/Slam2D"   type="string" value="true"/>
    <param name="Reg/Force3DoF"      type="string" value="true"/>

    <remap from="rgb/image"       to="/p3dx/camera/rgb/image_raw"/>
    <remap from="depth/image"     to="/p3dx/camera/depth/image_raw"/>
    <remap from="rgb/camera_info" to="/p3dx/camera/rgb/camera_info"/>
    <remap from="scan"            to="/p3dx/laser/scan"/>
    <remap from="odom"            to="/scanmatch_odom"/>
  </node>

  <node pkg="rviz" type="rviz" name="rviz"/>
</launch>
