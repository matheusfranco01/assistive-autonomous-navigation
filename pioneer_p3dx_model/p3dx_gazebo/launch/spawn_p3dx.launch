<?xml version="1.0"?>
<launch>

  <arg name="robot_namespace" default="p3dx"/>

  <arg name="initial_pose_x" default="5.0"/>
  <arg name="initial_pose_y" default="5.0"/>
  <arg name="initial_pose_a" default="0.0"/>

  <param name="robot_description" command="$(find xacro)/xacro '$(find p3dx_description)/urdf/p3dx.xacro'" />
  <include file="$(find p3dx_description)/launch/description.launch" />

  <param name="/initial_pose_x" value="$(arg initial_pose_x)" />
  <param name="/initial_pose_y" value="$(arg initial_pose_y)" />
  <param name="/initial_pose_a" value="$(arg initial_pose_a)" />

  <node pkg="p3dx_control" type="odom_shifter.py" name="odom_shifter_node" output="screen" respawn="true">
    <param name="initial_pose_x" value="$(arg initial_pose_x)" />
    <param name="initial_pose_y" value="$(arg initial_pose_y)" />
    <param name="initial_pose_a" value="$(arg initial_pose_a)" />
  </node>

  <include file="$(find p3dx_control)/launch/control.launch">
    <arg name="initial_pose_x" value="$(arg initial_pose_x)"/>
    <arg name="initial_pose_y" value="$(arg initial_pose_y)"/>
    <arg name="initial_pose_a" value="$(arg initial_pose_a)"/>
  </include>

 <node name="spawn_p3dx_model" pkg="gazebo_ros" type="spawn_model" 
        output="screen"
        launch-prefix="bash -c 'sleep 3; exec \"$@\"' _"
        args="-x $(arg initial_pose_x)
              -y $(arg initial_pose_y)
              -Y $(arg initial_pose_a)
              -urdf
              -param robot_description
              -model p3dx
              -pose p3dx_initial_pose" />

</launch>